{
  "name": "jailbreakchangelogs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run generate:icons && next dev -p 5500",
    "build": "bun run generate:icons && next build",
    "build:analyze": "ANALYZE=true next build",
    "generate:icons": "bun scripts/generate-icon-bundle.ts && oxfmt src/lib/icon-bundle.generated.ts",
    "analyze": "next experimental-analyze",
    "start": "next start -p 5500",
    "start:cf": "sh ./scripts/start-with-tunnel.sh",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "type-check": "tsc --noEmit",
    "check": "bun run format:check && bun run type-check && bun run lint",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src",
    "release": "bun --env-file=.env.local --bun release-it",
    "clean": "rm -rf .next node_modules && bun install",
    "bump-nextjs": "bunx @next/codemod upgrade latest",
    "prepare": "husky"
  },
  "dependencies": {
